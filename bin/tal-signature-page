#! /usr/bin/env python3
"""Compose a TAL phylogenetic tree + antigenic map(s) into one signature-page PDF.

  # tree + a pre-rendered (e.g. kateri) antigenic map, side by side:
  tal-signature-page --labels --color-by-clade --clades --map map.pdf tree.json out.pdf

  # render the map from a chart via kateri (requires the `kateri` executable on PATH):
  tal-signature-page --chart chart.ace --map-width 800 tree.json out.pdf

  # highlight vaccine/reference strains on the tree:
  tal-signature-page --mark "STRAIN/1,STRAIN/2" --map map.pdf tree.json out.pdf

The output PDF is exactly what py/ae/report's `signature_page` page type embeds.
"""

import argparse
import os
import sys

# Make the in-tree `ae` package (and the built ae_backend, for the kateri path)
# importable when run directly from a checkout, without relying on PYTHONPATH.
_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, os.path.join(_ROOT, "py"))
sys.path.insert(0, os.path.join(_ROOT, "build"))

from ae.tal.signature_page import make_signature_page, SignaturePageError


def main() -> int:
    parser = argparse.ArgumentParser(description="Compose a TAL tree + antigenic map(s) into a signature-page PDF")
    parser.add_argument("tree", help="tree file (newick or phylo-tree-v3 json[.xz])")
    parser.add_argument("output", help="output signature-page PDF")
    parser.add_argument("--map", action="append", default=[], dest="maps", metavar="MAP.pdf",
                        help="antigenic-map PDF to place on the right (repeatable; e.g. pre-rendered by kateri)")
    parser.add_argument("--chart", metavar="CHART.ace", help="chart to render to a map via kateri (requires the kateri executable)")
    parser.add_argument("--settings", metavar="FILE", help="tal-draw JSON settings file for the tree")
    parser.add_argument("--tal", metavar="CONFIG.tal", help="an acmacs-tal settings-v3 config; translated to the tal-draw schema (structural)")
    parser.add_argument("-D", "--define", action="append", default=[], metavar="name=value", help="define a $variable used by --tal (repeatable)")
    parser.add_argument("--mark", metavar="ID,ID,...", help="comma-separated seq_ids to highlight on the tree (e.g. vaccine/reference strains)")
    parser.add_argument("--mark-vaccines", metavar="SUBTYPE", help="highlight WHO vaccine strains (red) for SUBTYPE (e.g. BV, BY, 'A(H3N2)') — reads --vaccines-file (needs ae_backend)")
    parser.add_argument("--vaccines-file", metavar="semantic_vaccines.py", help="path to acmacs-data/semantic_vaccines.py (required with --mark-vaccines)")
    parser.add_argument("--mark-reference", metavar="SUBTYPE", help="highlight hidb reference antigens (blue) for SUBTYPE (e.g. B, 'A(H3N2)') — needs ae_backend + hidb")
    parser.add_argument("--hidb-dir", metavar="DIR", help="directory with hidb5.{h1,h3,b}.json.xz (else $HIDB_V5); used by --mark-reference")
    parser.add_argument("--reference-tables", type=int, default=20, metavar="N", help="union reference antigens over the last N hidb tables (default 20)")
    parser.add_argument("--size", type=int, default=1000, help="tree panel size in px (default 1000)")
    parser.add_argument("--map-width", type=float, default=800.0, help="kateri map width in px (default 800)")
    parser.add_argument("--style", default="-", help="kateri style name (default '-')")
    parser.add_argument("--frame", action="store_true", help="draw a frame around each panel")
    # finer grid layout (uses pdflatex): per-map captions, a page title, and a real R×C grid
    parser.add_argument("--caption", action="append", default=[], dest="captions", metavar="TEXT",
                        help="caption for the corresponding --map (repeatable, in order); enables the grid layout")
    parser.add_argument("--page-title", metavar="TEXT", help="title across the top of the signature page")
    parser.add_argument("--tree-caption", metavar="TEXT", help="caption under the tree panel")
    parser.add_argument("--columns", type=int, metavar="N", help="maps per row in the grid (default ceil(sqrt(#maps)))")
    # common tal-draw passthrough flags (settings can express everything else)
    parser.add_argument("--labels", action="store_true")
    parser.add_argument("--color-by-clade", action="store_true")
    parser.add_argument("--clades", action="store_true")
    parser.add_argument("--time-series", action="store_true")
    args = parser.parse_args()

    # Section-maps mode: a .tal (with hz-sections) + a chart -> AD-style signature
    # page (tree left, one antigenic map per shown hz-section right, coupled).
    if args.tal and args.chart:
        from ae.tal.signature_page import make_section_signature_page
        defines = {}
        for d in args.define:
            name, eq, value = d.partition("=")
            defines[name] = value if eq else "true"
        try:
            out = make_section_signature_page(
                args.tree, args.chart, args.tal, args.output,
                size=args.size if "--size" in sys.argv[1:] else None, map_width=args.map_width,
                page_title=args.page_title, tree_caption=args.tree_caption, defines=defines)
        except SignaturePageError as err:
            print(f"ERROR: {err}", file=sys.stderr)
            return 2
        except Exception as err:
            import traceback; traceback.print_exc()
            print(f"ERROR: {err}", file=sys.stderr)
            return 2
        print(f"Wrote {out} (tree + per-hz-section antigenic maps)")
        return 0

    tal_draw_args = ["--" + flag.replace("_", "-") for flag in ("labels", "color_by_clade", "clades", "time_series") if getattr(args, flag)]
    mark = [s for s in args.mark.split(",") if s] if args.mark else None

    settings = args.settings
    if args.tal:  # translate an acmacs-tal settings-v3 config -> tal-draw schema
        import json
        import tempfile
        from ae.tal.settings_v3 import load_tal
        # -D name=value sets a $variable; bare -D name is a truthy flag (used by `if` conditions)
        defines = {}
        for d in args.define:
            name, eq, value = d.partition("=")
            defines[name] = value if eq else "true"
        schema, warnings = load_tal(args.tal, defines)
        for warning in warnings:
            print(f"  [tal] {warning}", file=sys.stderr)
        if "image_size" in schema and "--size" not in sys.argv[1:]:
            args.size = int(schema["image_size"])
        fd, settings = tempfile.mkstemp(suffix=".tal-schema.json")
        with os.fdopen(fd, "w") as handle:
            json.dump(schema, handle)

    try:
        out = make_signature_page(args.tree, args.output, maps=args.maps, chart=args.chart, size=args.size,
                                  settings=settings, mark=mark, mark_vaccines=args.mark_vaccines, vaccines_file=args.vaccines_file,
                                  mark_reference=args.mark_reference, hidb_dir=args.hidb_dir, reference_tables=args.reference_tables,
                                  style=args.style, map_width=args.map_width, tal_draw_args=tal_draw_args, frame=args.frame,
                                  captions=args.captions or None, page_title=args.page_title,
                                  tree_caption=args.tree_caption, columns=args.columns)
    except SignaturePageError as err:
        print(f"ERROR: {err}", file=sys.stderr)
        return 2
    except Exception as err:  # subprocess / IO failures
        print(f"ERROR: {err}", file=sys.stderr)
        return 2
    n_maps = len(args.maps) + (1 if args.chart else 0)
    print(f"Wrote {out} (tree + {n_maps} map{'s' if n_maps != 1 else ''}{', marked' if mark else ''})")
    return 0


if __name__ == "__main__":
    sys.exit(main())
