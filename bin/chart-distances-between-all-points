#! /usr/bin/env python3
"""Print pairwise distances between all points (antigens and sera) in a map.

By default prints all AG-SR distances.  Use --ag-ag to include antigen-antigen
distances and --sr-sr for serum-serum distances.  Disconnected points are
skipped.  Output: distance  point1  point2.
"""
import sys, math, argparse, traceback
from pathlib import Path
import ae_backend

def main(args: argparse.Namespace):
    chart = ae_backend.chart_v3.Chart(args.chart)
    if chart.number_of_projections() == 0:
        raise RuntimeError("chart has no projections")
    proj = chart.projection(args.projection)
    layout = proj.layout()
    n_ag = chart.number_of_antigens()
    n_sr = chart.number_of_sera()
    n = n_ag + n_sr

    names = (
        [f"AG {ag.designation()}" for _, ag in chart.select_all_antigens()] +
        [f"SR {sr.designation()}" for _, sr in chart.select_all_sera()]
    )

    coords = []
    for i in range(n):
        if layout.connected(i):
            coords.append(list(layout[i]))
        else:
            coords.append(None)

    def dist(a, b):
        return math.sqrt(sum((x - y) ** 2 for x, y in zip(a, b)))

    def print_pair(i, j):
        if coords[i] and coords[j]:
            print(f"{dist(coords[i], coords[j]):.6f}  {names[i]}  {names[j]}")

    for i in range(n_ag):
        for j in range(n_ag, n):
            print_pair(i, j)

    if args.ag_ag:
        for i in range(n_ag):
            for j in range(i + 1, n_ag):
                print_pair(i, j)

    if args.sr_sr:
        for i in range(n_ag, n):
            for j in range(i + 1, n):
                print_pair(i, j)

try:
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("chart", type=Path)
    parser.add_argument("-p", "--projection", type=int, default=0)
    parser.add_argument("--ag-ag", action="store_true", default=False, help="also include antigen-antigen distances")
    parser.add_argument("--sr-sr", action="store_true", default=False, help="also include serum-serum distances")
    args = parser.parse_args()
    exit_code = main(args) or 0
except Exception as err:
    print(f"> {err}\n{traceback.format_exc()}", file=sys.stderr)
    exit_code = 1
exit(exit_code)

# ======================================================================
