#! /usr/bin/env python3
"""Print layout (map coordinates) for each antigen and serum in a chart projection.

Output columns: AG|SR  index  x  y [z]  designation
Disconnected points are printed with nan coordinates unless --skip-disconnected is set.
"""
import sys, argparse, traceback
from pathlib import Path
import ae_backend

def main(args: argparse.Namespace):
    chart = ae_backend.chart_v3.Chart(args.chart)
    if chart.number_of_projections() == 0:
        raise RuntimeError("chart has no projections")
    proj = chart.projection(args.projection)
    layout = proj.layout()
    n_ag = chart.number_of_antigens()
    ndim = layout.number_of_dimensions()
    nan_coords = "  ".join(f"{'nan':>10}" for _ in range(ndim))

    for no, ag in chart.select_all_antigens():
        if layout.connected(no):
            coords = "  ".join(f"{c:10.6f}" for c in layout[no])
            print(f"AG {no:3d}  {coords}  {ag.designation()}")
        elif not args.skip_disconnected:
            print(f"AG {no:3d}  {nan_coords}  {ag.designation()}")

    for no, sr in chart.select_all_sera():
        idx = no + n_ag
        if layout.connected(idx):
            coords = "  ".join(f"{c:10.6f}" for c in layout[idx])
            print(f"SR {no:3d}  {coords}  {sr.designation()}")
        elif not args.skip_disconnected:
            print(f"SR {no:3d}  {nan_coords}  {sr.designation()}")

try:
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("chart", type=Path)
    parser.add_argument("-p", "--projection", type=int, default=0, help="projection index (default: 0, best)")
    parser.add_argument("--skip-disconnected", action="store_true", default=False, help="omit disconnected points from output")
    args = parser.parse_args()
    exit_code = main(args) or 0
except Exception as err:
    print(f"> {err}\n{traceback.format_exc()}", file=sys.stderr)
    exit_code = 1
exit(exit_code)

# ======================================================================
