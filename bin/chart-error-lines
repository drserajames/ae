#! /usr/bin/env python3
"""Print error lines: difference between expected and actual map distances.

For each antigen-serum pair with a numeric titer the expected distance is:
    expected = colbasis[serum] - log2(titer)
The actual distance is the Euclidean distance in the map layout.
The error (residual) is: actual - expected.

Output: error  actual  expected  AG_no  SR_no  titer  ag_designation  /  sr_designation
Sorted by absolute error descending.
"""
import sys, math, argparse, traceback
from pathlib import Path
import ae_backend

def main(args: argparse.Namespace):
    chart = ae_backend.chart_v3.Chart(args.chart)
    if chart.number_of_projections() == 0:
        raise RuntimeError("chart has no projections")

    proj = chart.projection(args.projection)
    layout = proj.layout()
    n_ag = chart.number_of_antigens()
    n_sr = chart.number_of_sera()

    mcb = proj.minimum_column_basis()
    column_bases = chart.column_bases(mcb)
    titers = chart.titers()

    rows = []
    for ag_no in range(n_ag):
        ag_idx = ag_no
        if not layout.connected(ag_idx):
            continue
        ag_coords = list(layout[ag_idx])
        for sr_no in range(n_sr):
            titer = titers.titer(ag_no, sr_no)
            if not titer.is_regular():
                continue
            sr_idx = sr_no + n_ag
            if not layout.connected(sr_idx):
                continue
            sr_coords = list(layout[sr_idx])
            actual = math.sqrt(sum((a - b) ** 2 for a, b in zip(ag_coords, sr_coords)))
            expected = column_bases[sr_no] - titer.logged()
            error = actual - expected
            rows.append((error, actual, expected, ag_no, sr_no, str(titer)))

    rows.sort(key=lambda r: abs(r[0]), reverse=True)

    ag_names = {no: ag.designation() for no, ag in chart.select_all_antigens()}
    sr_names = {no: sr.designation() for no, sr in chart.select_all_sera()}

    if args.top:
        rows = rows[:args.top]

    for error, actual, expected, ag_no, sr_no, titer in rows:
        print(f"{error:+.4f}  actual={actual:.4f}  exp={expected:.4f}  "
              f"AG {ag_no:3d}  SR {sr_no:3d}  {titer:>6}  "
              f"{ag_names[ag_no]}  /  {sr_names[sr_no]}")

    print(f"\n{len(rows)} error lines")

try:
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("chart", type=Path)
    parser.add_argument("-p", "--projection", type=int, default=0)
    parser.add_argument("--top", type=int, default=0, metavar="N", help="show only the N largest errors (default: all)")
    args = parser.parse_args()
    exit_code = main(args) or 0
except Exception as err:
    print(f"> {err}\n{traceback.format_exc()}", file=sys.stderr)
    exit_code = 1
exit(exit_code)

# ======================================================================
