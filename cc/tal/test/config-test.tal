{
    "_": "synthetic acmacs-tal settings-v3 config for test-settings-v3.py (no real data). Note the trailing commas + ?N disabled entries, which the relaxed loader must tolerate.",
    "tal": [
        {"N": "canvas", "height": 600},
        "clades-whocc",
        {"N": "tree", "color-by": "continent", "legend": {"show": true}},
        {"N": "clades", "per-clade": [
            {"name": "C1", "show": false},
            {"name": "C2", "color": "#1f78b4"},
        ]},
        "hz",
        {"N": "time-series", "start": "2020-01", "end": "2021-01"},
        {"N": "draw-aa-transitions", "method": "imported", "minimum-number-leaves-in-subtree": 5,
         "per-node": [
            {"name": "T1K", "show": true, "node_id": "3.5", "?first": "A", "?last": "C", "label": {"offset": [0.01, 0.0]}},
            {"name": "no-bounds", "show": true, "node_id": "9.9"}
         ]},
        {"N": "dash-bar-aa-at", "pos": 159},
        {"N": "nodes", "select": {"seq_id": "A"}, "apply": {"hide": true}},
        {"N": "nodes", "select": {"seq_id": "B"}, "apply": {"text": {"text": "x", "offset": [0.02, 0.0]}}},
        {"N": "nodes", "select": {"edge >=": 0.5, "?cumulative >=": 9}, "apply": {"hide": true}},
        {"N": "if", "condition": "$enable_extra", "then": [
            {"N": "dash-bar-aa-at", "pos": 145},
        ]},
        {"N": "if", "condition": {"not": "$enable_extra"}, "then": [
            {"N": "dash-bar-aa-at", "pos": 999},
        ]},
        {"?N": "gap", "width-to-height-ratio": 0.02},
    ],
    "hz": [
        {"N": "hz-sections", "sections": [
            {"first": "A", "last": "C", "label": "S1", "show": true},
        ]},
    ],
    "_clades-whocc": "report .tal defines its OWN clades-whocc sub-array (a clades command with the curated per-clade set); the translator must RUN it, not treat clades-whocc as a hardcoded builtin",
    "clades-whocc": [
        {"N": "clades", "all-clades": {"show": true}, "per-clade": [
            {"name": "WC_HIDDEN", "show": false},
            {"name": "WC_DISP", "display_name": "wc", "label": {"rotation_degrees": 90}},
        ]},
    ]
}
